{
  "name": "showcase",
  "version": "1.0.0",
  "description": "A blank template to get started with Payload 3.0",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "pnpm run lint && pnpm run typecheck && pnpm exec next build",
    "dev": "pnpm exec next dev",
    "devsafe": "pnpm exec next dev",
    "generate:importmap": "pnpm exec payload generate:importmap",
    "generate:types": "pnpm exec payload generate:types",
    "lint": "pnpm exec eslint .",
    "payload": "pnpm exec payload",
    "start": "pnpm exec next start",
    "typecheck": "pnpm exec tsc --noEmit --pretty false -p tsconfig.typecheck.json"
  },
  "dependencies": {
    "@fdorantesm/react-skill-icons": "^1.0.7",
    "@payloadcms/db-postgres": "3.79.0",
    "@payloadcms/live-preview": "3.79.0",
    "@payloadcms/next": "3.79.0",
    "@payloadcms/richtext-lexical": "3.79.0",
    "@payloadcms/translations": "^3.79.0",
    "@payloadcms/ui": "3.79.0",
    "@tailwindcss/postcss": "^4.2.1",
    "dotenv": "16.4.7",
    "graphql": "^16.8.1",
    "motion": "^12.36.0",
    "next": "16.1.5",
    "openai": "^6.32.0",
    "payload": "3.79.0",
    "postcss": "^8.5.8",
    "react": "19.2.1",
    "react-countup": "^6.5.3",
    "react-dom": "19.2.1",
    "react-icons": "^5.6.0",
    "sharp": "0.34.2",
    "tailwindcss": "^4.2.1",
    "typed.js": "^3.0.0"
  },
  "devDependencies": {
    "@types/node": "22.19.9",
    "@types/react": "19.2.9",
    "@types/react-dom": "19.2.3",
    "eslint": "^9.16.0",
    "eslint-config-next": "15.4.11",
    "prettier": "^3.4.2",
    "tsx": "4.21.0",
    "typescript": "5.7.3"
  },
  "engines": {
    "node": "^18.20.2 || >=20.9.0",
    "pnpm": "^9 || ^10"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "sharp",
      "esbuild",
      "unrs-resolver"
    ]
  }
}
